<Window x:Class="GitPullTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitPullTool"
        mc:Ignorable="d"
        Title="Git Pull Tool" Height="450" Width="800">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Orientation="Horizontal">
      <TextBox x:Name="SourcePath" Width="500" Margin="0,0,10,0"/>
      <Button Content="Browse" Click="Browse_Click" Width="80"/>
      <Button Name="RunButton" Content="Run" Click="Run_Click" Width="80" Margin="10,0,0,0"/>
    </StackPanel>
    <DataGrid x:Name="ResultsGrid" Grid.Row="1" AutoGenerateColumns="True" Margin="0,10,0,10"/>
    <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="20" Minimum="0" Maximum="100"/>
  </Grid>
</Window>
